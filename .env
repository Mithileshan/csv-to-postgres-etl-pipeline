# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/etl_db
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=etl_db
DATABASE_USER=postgres
